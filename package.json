{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxi build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:neon:generate": "drizzle-kit generate:pg --config=./server/database/drizzle.neon.config.ts",
    "db:neon:push": "drizzle-kit push:pg --config=./server/database/drizzle.neon.config.ts",
    "db:d1:generate": "drizzle-kit generate:sqlite --config=./server/database/drizzle.d1.config.ts",
    "db:d1:push": "drizzle-kit push:sqlite --config=./server/database/drizzle.d1.config.ts",
    "db:all:migrate": "pnpm run db:neon:generate && pnpm run db:neon:push && pnpm run db:d1:generate && pnpm run db:d1:push"
  },
  "dependencies": {
    "@kristianbinau/nuxt-maintenance-mode": "0.0.6",
    "@neondatabase/serverless": "^1.0.1",
    "@nuxt/content": "^3.7.1",
    "@nuxt/eslint": "^1.9.0",
    "@nuxt/image": "^1.11.0",
    "@nuxt/scripts": "0.11.13",
    "@nuxt/ui": "4.0.0-alpha.2",
    "@nuxthub/core": "^0.9.0",
    "@nuxtjs/i18n": "^10.1.0",
    "@nuxtjs/robots": "5.5.5",
    "@nuxtjs/sitemap": "7.4.7",
    "@nuxtjs/turnstile": "1.1.0",
    "@unhead/vue": "^2.0.17",
    "@vercel/blob": "^1.1.1",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.9.0",
    "better-sqlite3": "^12.2.0",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "motion-v": "^1.7.1",
    "nuxt": "^4.1.0",
    "nuxt-og-image": "^5.1.11",
    "sharp": "^0.34.4",
    "typescript": "^5.9.2",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
